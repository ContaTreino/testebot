def mention(user) -> str:
    name = ((user.first_name or "") + (" " + user.last_name if user.last_name else "")).strip()
    name = name or f"id{user.id}"
    return f"@{user.username}" if user.username else f'<a href="tg://user?id={user.id}">{name}</a>'

