# ╚══════════════════════════════════════════════════════════════════╝
def _v(val, default="N/A"):
    if val is None: return default
    s = str(val).strip()
    return default if s in ("","0","None","null","N/A") else s

def _valid_url(u):
    if not u or not isinstance(u, str): return False
    return u.strip().startswith("http") and len(u.strip()) > 12

def montar_card_filme(result, info, index, total, sid, creds, searcher_mention=""):
    info      = info or {}
    stream_id = result.get("stream_id", "")
    ext       = _v(result.get("container_extension"), "mkv")
    title     = _v(result.get("name"), "Título desconhecido")
    image     = (_v(info.get("movie_image")) or _v(info.get("cover_big"))
                 or _v(result.get("stream_icon")) or FALLBACK_IMG)
    if not _valid_url(image): image = FALLBACK_IMG

    desc     = _v(info.get("description") or info.get("plot"))
    genre    = _v(info.get("genre")); director = _v(info.get("director"))
    actors   = _v(info.get("actors") or info.get("cast"))
    duration = _v(info.get("duration")); country = _v(info.get("country"))
    release  = _v(info.get("releasedate")); trailer = info.get("youtube_trailer","")
    rating   = _v(info.get("rating") or result.get("rating"))
    year     = release[:4] if release and release != "N/A" else _v(result.get("year"))

    try:
        r5 = float(_v(result.get("rating_5based"), "0"))
        stars = "⭐" * min(5, max(0, round(r5))) if r5 > 0 else ""
    except: stars = ""

    lines = [f"🎬 <b>{title}</b>"]
    if searcher_mention: lines.append(f"🔍 <i>Buscado por {searcher_mention}</i>")
    lines.append("─" * 28)
    if year     != "N/A": lines.append(f"📅 <b>Ano:</b> {year}")
    if rating   != "N/A": lines.append(f"⭐ <b>Nota:</b> {rating}  {stars}".rstrip())
    if duration != "N/A": lines.append(f"⏱ <b>Duração:</b> {duration}")
    if genre    != "N/A": lines.append(f"🎭 <b>Gênero:</b> {genre}")
    if country  != "N/A": lines.append(f"🌎 <b>País:</b> {country}")
    if director != "N/A": lines.append(f"🎥 <b>Diretor:</b> {director}")
    if actors   != "N/A":
        a = actors[:90] + "…" if len(actors) > 90 else actors
        lines.append(f"🎭 <b>Elenco:</b> {a}")
    if desc != "N/A":
        d = desc[:190] + "…" if len(desc) > 190 else desc
        lines += ["─" * 28, f"📖 {d}"]
    lines += ["─" * 28, f"📄 <b>{index+1} de {total}</b>"]
    caption = "\n".join(lines)

    kb  = InlineKeyboardMarkup(row_width=2)
    nav = []
    if index > 0:       nav.append(InlineKeyboardButton("⬅️ Voltar",    callback_data=f"n|{sid}|{index-1}"))
    if index < total-1: nav.append(InlineKeyboardButton("Avançar ➡️", callback_data=f"n|{sid}|{index+1}"))
    if nav: kb.row(*nav)

    watch = stream_url(creds, stream_id, ext)
    row2  = [InlineKeyboardButton("▶️ Assistir", url=watch)]
    if trailer and str(trailer).strip():
        row2.append(InlineKeyboardButton("🎞 Trailer YT", url=f"https://youtu.be/{trailer}"))
    kb.row(*row2)
    kb.row(InlineKeyboardButton("🔍 Nova Busca", callback_data=f"nb|{sid}"))
    return image, caption, kb

