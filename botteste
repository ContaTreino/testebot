    try: return api_get(creds, {"action": "get_vod_info", "vod_id": vod_id})
    except Exception as e: logging.error(f"buscar_info_filme: {e}"); return None

def buscar_por_nome(creds, termo):
    try:
        data = api_get(creds, {"action": "get_vod_streams"}, timeout=30)
        if re.match(r'^\d+$', termo.strip()):
            match = [i for i in data if str(i.get("stream_id","")) == termo.strip()]
            return match or None
        termo_limpo = termo.lstrip("@").strip()
        t = unidecode(termo_limpo.lower())
        return [i for i in data if t in unidecode(str(i.get("name",""))).lower()] or None
    except Exception as e: logging.error(f"buscar_por_nome: {e}"); return None

def stream_url(creds, stream_id, ext):
    return f"{creds['base']}/movie/{creds['username']}/{creds['password']}/{stream_id}.{ext}"

