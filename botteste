# ║              DOWNLOAD — deemix (álbum / faixa)                  ║
# ╚══════════════════════════════════════════════════════════════════╝
def _deemix_download(dz_url: str, uid: int, is_album: bool) -> list | None:
    """
    Faz download via deemix e retorna lista de caminhos de arquivos.
    Para álbuns usa ffmpeg (merge + tag) através das opções do deemix.
    Aceita URL do Deezer ou do Spotify — o deemix resolve automaticamente.
    """
    try:
        from deemix              import generateDownloadObject
        from deemix.settings     import load as loadSettings
        from deemix.downloader   import Downloader
        from deezer              import Deezer
    except ImportError:
        le("deemix/deezer-python não instalado. Execute: pip install deemix deezer-python")
        return None

    try:
        qualidade = get_qual(uid)
        bitrate   = QUAL_MAP.get(qualidade, "1")
        dest      = os.path.join(MUSIC_DIR, str(uid))
        os.makedirs(dest, exist_ok=True)

        dz  = Deezer()
        arl = _cfg().get("deezer_arl", "").strip()
        if not arl or not dz.login_via_arl(arl):
            le("ARL Deezer inválida ou expirada.")
            return None

        settings = loadSettings()
        settings["downloadLocation"]    = dest
        settings["maxBitrate"]          = bitrate
        settings["createArtistFolder"]  = False
        settings["createAlbumFolder"]   = is_album    # pasta por álbum somente para álbuns
        settings["saveArtworkArtist"]   = False
        settings["saveArtwork"]         = is_album
        # ffmpeg só é acionado pelo deemix em conversões e merge de álbum
        settings["featuredToTitle"]     = False
        settings["overwriteFile"]       = "y"

        snapshot_before = set(Path(dest).rglob("*"))

        obj = generateDownloadObject(dz, dz_url, bitrate)
        if isinstance(obj, list):
            for o in obj: Downloader(dz, o, settings).start()
        else:
            Downloader(dz, obj, settings).start()

        snapshot_after = set(Path(dest).rglob("*"))
        new_files = sorted(
            str(f) for f in (snapshot_after - snapshot_before)
            if Path(f).is_file() and Path(f).suffix.lower() in ('.mp3', '.flac', '.ogg', '.opus')
        )
        return new_files or None
    except Exception as e:
        logging.error(f"_deemix_download: {e}"); return None


def _executar_download_e_enviar(chat_id, tid, uid, dz_url, is_album,
                                prog_msg_id, nome_exibicao: str):
    """
    Thread de download: baixa, envia os arquivos e limpa a pasta temporária.
    """
    qual_label = QUAL_LABEL.get(get_qual(uid), "?")
    tipo_str   = "álbum" if is_album else "faixa"

    def _edit(txt):
        try: bot.edit_message_text(txt, chat_id=chat_id,
                                   message_id=prog_msg_id, parse_mode='HTML')
        except: pass

    _edit(f"⏳ Baixando {tipo_str} <b>{nome_exibicao}</b> em {qual_label}…\n"
          f"<i>Aguarde, isso pode levar alguns instantes.</i>")

    files = _deemix_download(dz_url, uid, is_album)

    if not files:
        _edit("❌ <b>Falha no download.</b>\n\n"
              "Verifique:\n"
              "• A ARL Deezer está válida? (Painel Admin → Música)\n"
              "• A URL é de álbum ou faixa (playlists não são aceitas)\n"
              "• deemix e deezer-python estão instalados")
        return

    _edit(f"📤 Enviando <b>{len(files)}</b> arquivo(s)…")

    for fpath in files:
        try:
            with open(fpath, 'rb') as f:
                kw = {"message_thread_id": tid} if tid else {}
                bot.send_audio(chat_id, f, **kw)
            os.remove(fpath)
        except Exception as e:
            logging.error(f"send_audio: {e}")

    # Limpa pasta do usuário após envio
    user_dir = os.path.join(MUSIC_DIR, str(uid))
    try:
        shutil.rmtree(user_dir, ignore_errors=True)
    except: pass

    _try_delete(chat_id, prog_msg_id)
    lok(f"Download concluído: {nome_exibicao} ({len(files)} arquivo(s))")

