# ║               DETECÇÃO E VALIDAÇÃO DE URL MUSICAL               ║
# ╔══════════════════════════════════════════════════════════════════╝
# Padrões aceitos
_RE_DZ_ALBUM   = re.compile(r'deezer\.com(?:/[a-z]{2})?/album/(\d+)',      re.I)
_RE_DZ_TRACK   = re.compile(r'deezer\.com(?:/[a-z]{2})?/track/(\d+)',      re.I)
_RE_SP_ALBUM   = re.compile(r'open\.spotify\.com/album/([A-Za-z0-9]+)',    re.I)
_RE_SP_TRACK   = re.compile(r'open\.spotify\.com/track/([A-Za-z0-9]+)',    re.I)
# Playlists — bloqueadas
_RE_DZ_PL      = re.compile(r'deezer\.com(?:/[a-z]{2})?/playlist/',        re.I)
_RE_SP_PL      = re.compile(r'open\.spotify\.com/playlist/',               re.I)

def classificar_url_musical(text: str):
    """
    Retorna (tipo, id_ou_url) onde tipo é:
      'dz_album'  | 'dz_track'
      'sp_album'  | 'sp_track'
      'playlist'  → bloqueado
      None        → não é URL musical
    """
    text = text.strip()
    if _RE_DZ_PL.search(text) or _RE_SP_PL.search(text):
        return 'playlist', None
    m = _RE_DZ_ALBUM.search(text)
    if m: return 'dz_album', m.group(1)
    m = _RE_DZ_TRACK.search(text)
    if m: return 'dz_track', m.group(1)
    m = _RE_SP_ALBUM.search(text)
    if m: return 'sp_album', m.group(1)
    m = _RE_SP_TRACK.search(text)
    if m: return 'sp_track', m.group(1)
    return None, None

