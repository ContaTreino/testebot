# ╔══════════════════════════════════════════════════════════════════╗
# ║           HANDLER DE TEXTO CENTRAL                              ║
# ║   • busca direta @Bot Termo                                     ║
# ║   • estados pendentes (busca filme, URL musical, admin)         ║
# ╚══════════════════════════════════════════════════════════════════╝
_BOT_PREFIX_RE = re.compile(r'^@(\w+)\s+(.+)$', re.IGNORECASE | re.DOTALL)

@bot.message_handler(content_types=['text'])
def h_text(message):
    uid   = message.from_user.id
    state = _pending.get(uid, {})
    text  = (message.text or "").strip()

    # ── Busca direta por menção @Bot Termo ────────────────────────
    m = _BOT_PREFIX_RE.match(text)
    if m and not state:
        try:
            me = bot.get_me()
            if m.group(1).lower() == me.username.lower():
                if not is_allowed(message): return
                termo   = m.group(2).strip()
                creds   = get_active_creds()
                tid     = _thread(message); chat_id = message.chat.id
                u       = message.from_user
                salvar_usuario(u.id, u.username or '', u.full_name or '')
                lu(u.full_name, f"Busca direta: {termo}")
                try: bot.delete_message(chat_id, message.message_id)
                except: pass
                if not creds:
                    send_msg(chat_id, "❌ Nenhuma URL configurada.", thread_id=tid, parse_mode='HTML')
                    return
                sm   = send_msg(chat_id, "🔍 Iniciando busca...", thread_id=tid)
                anim = threading.Thread(target=loading_animation,
                                        args=(chat_id, sm.message_id, tid), daemon=True)
                anim.start()
                results = buscar_por_nome(creds, termo)
                anim.join()
                if not results:
                    kb2, txt2 = kb_user_main(is_owner=(uid == OWNER_ID), uid=uid)
                    send_msg(chat_id, f"❌ <b>Nenhum resultado para:</b> <i>{termo}</i>",
                             thread_id=tid, parse_mode='HTML', reply_markup=kb2)
                    return
                _finalizar_busca_filme(chat_id, tid, uid, results, creds, u)
                return
        except Exception as e: logging.error(f"busca_direta: {e}")

    if not state: return
    action = state.get('action')

    # ── Aguardando termo de busca de filme ────────────────────────
    if action == 'search_term':
        del _pending[uid]
        termo   = text
        creds   = state.get('creds') or get_active_creds()
        tid     = state.get('thread_id') or _thread(message)
        chat_id = message.chat.id
        lu(message.from_user.full_name, f"Busca: {termo}")
        try: bot.delete_message(chat_id, message.message_id)
        except: pass
        if not creds:
            send_msg(chat_id, "❌ Nenhuma URL configurada.", thread_id=tid)
            return
        sm   = send_msg(chat_id, "🔍 Iniciando busca...", thread_id=tid)
        anim = threading.Thread(target=loading_animation,
                                args=(chat_id, sm.message_id, tid), daemon=True)
        anim.start()
        results = buscar_por_nome(creds, termo)
        anim.join()
        if not results:
            kb2, txt2 = kb_user_main(is_owner=(uid == OWNER_ID), uid=uid)
            send_msg(chat_id, f"❌ <b>Nenhum resultado para:</b> <i>{termo}</i>",
                     thread_id=tid, parse_mode='HTML', reply_markup=kb2)
            return
        _finalizar_busca_filme(chat_id, tid, uid, results, creds, message.from_user)
        return

    # ── Aguardando URL musical (Deezer ou Spotify) ────────────────
    if action == 'search_musica':
        del _pending[uid]
        url_input = text
        tid       = state.get('thread_id') or _thread(message)
        chat_id   = message.chat.id
        try: bot.delete_message(chat_id, message.message_id)
        except: pass

        if not _cfg().get("musica_ativa"):
            send_msg(chat_id, "❌ Módulo de música desativado.", thread_id=tid, parse_mode='HTML')
            return
        if not is_auth_musica(uid):
            send_msg(chat_id, "🚫 Você não está autorizado para downloads.",
                     thread_id=tid, parse_mode='HTML')
            return

        tipo, item_id = classificar_url_musical(url_input)

        if tipo == 'playlist':
            kb_cancel = InlineKeyboardMarkup()
            kb_cancel.add(InlineKeyboardButton("↩ Menu", callback_data="usr|cancel"))
            send_msg(chat_id,
                "🚫 <b>Playlists não são aceitas.</b>\n\n"
                "Envie apenas URL de:\n"
                "• 🎵 Faixa individual\n"
                "• 💿 Álbum completo\n\n"
                "<i>Deezer ou Spotify</i>",
                thread_id=tid, parse_mode='HTML', reply_markup=kb_cancel)
            return

        if tipo is None:
            kb_cancel = InlineKeyboardMarkup()
            kb_cancel.add(InlineKeyboardButton("↩ Menu", callback_data="usr|cancel"))
            send_msg(chat_id,
                "❌ <b>URL não reconhecida.</b>\n\n"
                "Envie um link válido de:\n"
                "• <code>https://www.deezer.com/track/XXXXXX</code>\n"
                "• <code>https://www.deezer.com/album/XXXXXX</code>\n"
                "• <code>https://open.spotify.com/track/XXXXXX</code>\n"
                "• <code>https://open.spotify.com/album/XXXXXX</code>",
                thread_id=tid, parse_mode='HTML', reply_markup=kb_cancel)
            return

        is_album   = tipo in ('dz_album', 'sp_album')
        qual_label = QUAL_LABEL.get(get_qual(uid), "?")

        # Busca metadados para exibir card antes do download
        prog = send_msg(chat_id, "🔍 Buscando informações…", thread_id=tid, parse_mode='HTML')

        if tipo == 'dz_album':
            meta = metadados_album_deezer(item_id)
        elif tipo == 'dz_track':
            meta = metadados_track_deezer(item_id)
        elif tipo == 'sp_album':
            # Para Spotify, deemix resolve internamente; tentamos buscar no Deezer via ISRC
            # Mostramos card genérico e passamos a URL original ao deemix
            meta = None
        else:   # sp_track
            meta = None

        try: bot.delete_message(chat_id, prog.message_id)
        except: pass

        lu(message.from_user.full_name,
           f"Música {'álbum' if is_album else 'faixa'} — {url_input[:60]}")

        if meta and tipo == 'dz_album':
            cover, caption, kb_card = montar_card_album(meta, qual_label)
            # Guarda url original para callback de download
            _pending[uid] = {
                '_dl_url':    url_input,
                '_dl_album':  True,
                '_dl_nome':   meta.get("title", "Álbum"),
                '_dl_tid':    tid,
                '_dl_chat':   chat_id,
            }
            send_photo(chat_id, cover, caption, kb_card, thread_id=tid)
            return

        if meta and tipo == 'dz_track':
            cover, caption, kb_card = montar_card_track(meta, qual_label)
            _pending[uid] = {
                '_dl_url':   url_input,
                '_dl_album': False,
                '_dl_nome':  meta.get("title", "Faixa"),
                '_dl_tid':   tid,
                '_dl_chat':  chat_id,
            }
            send_photo(chat_id, cover, caption, kb_card, thread_id=tid)
            return

        # Spotify ou metadados indisponíveis → download direto sem card
        nome_exib = "Spotify — " + ("álbum" if is_album else "faixa")
        prog2     = send_msg(chat_id, "⏳ Preparando download…", thread_id=tid, parse_mode='HTML')
        threading.Thread(
            target=_executar_download_e_enviar,
            args=(chat_id, tid, uid, url_input, is_album, prog2.message_id, nome_exib),
            daemon=True
        ).start()
        return

    # ── Aguardando ARL Deezer (somente dono) ─────────────────────
    if action == 'await_arl' and uid == OWNER_ID:
        del _pending[uid]
        arl_value = text.strip()
        try: bot.delete_message(message.chat.id, message.message_id)
        except: pass
        if len(arl_value) < 100:
            send_msg(uid, "❌ ARL parece inválida (muito curta). Tente novamente.",
                     parse_mode='HTML')
            return
        _cfg_set("deezer_arl", arl_value)
        lok("ARL Deezer atualizada")
        send_msg(uid,
            f"✅ <b>ARL Deezer configurada!</b>\n🔑 <code>{arl_value[:12]}…</code>",
            parse_mode='HTML')
        kb2, txt2 = kb_musica_menu()
        send_msg(uid, txt2, parse_mode='HTML', reply_markup=kb2)
        return

    # ── Aguardando UID para autorizar música (somente dono) ───────
    if action == 'await_auth_uid' and uid == OWNER_ID:
        del _pending[uid]
        try: bot.delete_message(message.chat.id, message.message_id)
        except: pass
        try: target_uid = int(text.strip())
        except ValueError:
            send_msg(uid, "❌ ID inválido. Envie apenas o número.", parse_mode='HTML')
            return
        auth_add(target_uid)
        send_msg(uid, f"✅ Usuário <code>{target_uid}</code> autorizado!", parse_mode='HTML')
        kb2, txt2 = kb_musica_menu()
        send_msg(uid, txt2, parse_mode='HTML', reply_markup=kb2)
        return

    # ── Aguardando label da URL de streaming ──────────────────────
    if action == 'await_label' and uid == OWNER_ID:
        label = text[:40]
        _pending[uid] = {'action': 'await_url', 'label': label,
                         'menu_chat': state['menu_chat'], 'menu_msg': state['menu_msg']}
        try: bot.delete_message(message.chat.id, message.message_id)
        except: pass
        send_msg(uid,
            "📡 <b>Agora envie a URL do portal de streaming:</b>\n\n"
            "<code>http://host:80/get.php?username=U&password=P</code>\n"
            "<code>http://host:80/player_api.php?username=U&password=P</code>\n"
            "<code>http://host:80/U/P/arquivo.mkv</code>",
            parse_mode='HTML')
        return

    # ── Aguardando a URL de streaming em si ──────────────────────
    if action == 'await_url' and uid == OWNER_ID:
        url = text; del _pending[uid]
        try: bot.delete_message(message.chat.id, message.message_id)
        except: pass
        ok, result = url_add(url, state.get('label', f"URL {len(_urls()['list'])+1}"))
        info_txt = (
            f"✅ <b>URL adicionada!</b>\n\n"
            f"🖥 <code>{result['host']}:{result['port']}</code>\n"
            f"👤 <code>{result['username']}</code>"
        ) if ok else result
        if ok: lok(f"URL adicionada: {result['host']}")
        kb2, txt2 = kb_urls_menu()
        try: bot.edit_message_text(txt2, chat_id=state['menu_chat'],
                                   message_id=state['menu_msg'],
                                   parse_mode='HTML', reply_markup=kb2)
        except: send_msg(uid, txt2, parse_mode='HTML', reply_markup=kb2)
        send_msg(uid, info_txt, parse_mode='HTML')
        return

    # ── Aguardando CHAT_ID e THREAD_ID do grupo ───────────────────
    if action == 'await_group_id' and uid == OWNER_ID:
        del _pending[uid]
        try: bot.delete_message(message.chat.id, message.message_id)
        except: pass
        parts = re.split(r'[\s,]+', text)
        if len(parts) < 2:
            send_msg(uid,
                "❌ Formato: <code>CHAT_ID THREAD_ID Nome do Grupo</code>\n"
                "Ex: <code>-1001234567890 5 Filmes HD</code>", parse_mode='HTML')
            return
        try:
            chat_id   = int(parts[0]); thread_id = int(parts[1])
            title     = " ".join(parts[2:]) if len(parts) > 2 else f"Grupo {parts[0]}"
            group_set(chat_id, thread_id, title)
            lok(f"Grupo adicionado: {chat_id} tópico {thread_id}")
            kb2, txt2 = kb_grupos_menu()
            try: bot.edit_message_text(txt2, chat_id=state['menu_chat'],
                                       message_id=state['menu_msg'],
                                       parse_mode='HTML', reply_markup=kb2)
            except: send_msg(uid, txt2, parse_mode='HTML', reply_markup=kb2)
            send_msg(uid,
                f"✅ Grupo <code>{chat_id}</code> adicionado!\n"
                f"📌 Tópico: <code>{thread_id}</code>  |  📛 <b>{title}</b>",
                parse_mode='HTML')
        except ValueError:
            send_msg(uid, "❌ IDs inválidos. Use apenas números inteiros.", parse_mode='HTML')

# ── Helper: finaliza busca de filme, salva sessão e envia card ────
def _finalizar_busca_filme(chat_id, tid, uid, results, creds, user_obj):
    first      = results[0]; vod_id = first.get("stream_id")
    first_info = {}
    try:
        resp = buscar_info_filme(creds, vod_id)
        first_info = resp.get("info", {}) if resp else {}
    except: pass
    sid = _new_sid(chat_id, uid)
    infos = [None] * len(results); infos[0] = first_info
    _sessions[sid] = {'user_id': uid, 'results': results, 'infos': infos,
                      'index': 0, 'creds': creds,
                      'chat_id': chat_id, 'thread_id': tid, 'user': user_obj}
    searcher = mention(user_obj)
    img, caption, kb = montar_card_filme(first, first_info, 0, len(results),
                                         sid, creds, searcher_mention=searcher)
    lok(f"{len(results)} resultado(s)")
    send_photo(chat_id, img, caption, kb, thread_id=tid)

# ╔══════════════════════════════════════════════════════════════════╗
# ║                  CALLBACK HANDLER CENTRAL                       ║
# ╚══════════════════════════════════════════════════════════════════╝
@bot.callback_query_handler(func=lambda c: True)
def h_callback(call):
    uid  = call.from_user.id
    data = call.data
    now  = time.time()

    if now - _cooldown.get(uid, 0) < 0.7:
        bot.answer_callback_query(call.id, "⏳ Aguarde..."); return
    _cooldown[uid] = now

    try:
        parts  = data.split('|')
        action = parts[0]

        # ════════════════════════════════════════════════════
        # NAVEGAÇÃO DO CARD DE FILME  n|{sid}|{idx}
        # ════════════════════════════════════════════════════
        if action == 'n' and len(parts) == 3:
            sid = int(parts[1]); idx = int(parts[2])
            owner = _owner(sid)
            if owner is None:
                bot.answer_callback_query(call.id, "⚠️ Sessão expirada.", show_alert=True); return
            if owner != uid:
                bot.answer_callback_query(call.id, "🚫 Esta navegação não é sua."); return
            sess = _sessions[sid]
            results = sess['results']; infos = sess['infos']
            creds   = sess['creds'];   user_obj = sess.get('user', call.from_user)
            if not (0 <= idx < len(results)):
                bot.answer_callback_query(call.id, "Índice inválido."); return
            sess['index'] = idx
            if infos[idx] is None:
                bot.answer_callback_query(call.id, "⏳ Carregando detalhes...")
                vod_id = results[idx].get("stream_id")
                try:
                    resp = buscar_info_filme(creds, vod_id)
                    infos[idx] = resp.get("info", {}) if resp else {}
                except: infos[idx] = {}
            else:
                bot.answer_callback_query(call.id)
            img, caption, kb = montar_card_filme(
                results[idx], infos[idx], idx, len(results),
                sid, creds, searcher_mention=mention(user_obj))
            try:
                bot.edit_message_media(
                    media=telebot.types.InputMediaPhoto(media=img, caption=caption, parse_mode='HTML'),
                    chat_id=call.message.chat.id, message_id=call.message.message_id,
                    reply_markup=kb)
            except:
                try:
                    bot.edit_message_caption(caption=caption, chat_id=call.message.chat.id,
                                             message_id=call.message.message_id,
                                             parse_mode='HTML', reply_markup=kb)
                except Exception as e2: le(f"edit_caption: {e2}")
            return

        # ════════════════════════════════════════════════════
        # NOVA BUSCA  nb|{sid}
        # ════════════════════════════════════════════════════
        if action == 'nb' and len(parts) == 2:
            sid = int(parts[1])
            if _owner(sid) not in (None, uid):
                bot.answer_callback_query(call.id, "🚫 Não é sua sessão."); return
            if sid in _sessions: del _sessions[sid]
            bot.answer_callback_query(call.id)
            kb2, txt2 = kb_user_main(is_owner=(uid == OWNER_ID), uid=uid)
            try: bot.delete_message(call.message.chat.id, call.message.message_id)
            except: pass
            send_msg(call.message.chat.id, txt2,
                     thread_id=getattr(call.message, 'message_thread_id', None),
                     parse_mode='HTML', reply_markup=kb2)
            return

        # ════════════════════════════════════════════════════
        # USUÁRIO
        # ════════════════════════════════════════════════════
        if action == 'usr':
            sub = parts[1]

            # ── Buscar filme ──────────────────────────────
            if sub == 'buscar':
                bot.answer_callback_query(call.id)
                creds = get_active_creds()
                if not creds:
                    bot.answer_callback_query(call.id, "❌ Nenhuma URL configurada.", show_alert=True)
                    return
                _pending[uid] = {
                    'action':    'search_term',
                    'chat_id':   call.message.chat.id,
                    'thread_id': getattr(call.message, 'message_thread_id', None),
                    'creds':     creds,
                }
                try: bot.delete_message(call.message.chat.id, call.message.message_id)
                except: pass
                kb_cancel = InlineKeyboardMarkup()
                kb_cancel.add(InlineKeyboardButton("❌ Cancelar", callback_data="usr|cancel"))
                send_msg(call.message.chat.id,
                    "🔍 <b>Digite o nome do filme:</b>\n\n"
                    "💡 Ou mencione direto no tópico:\n"
                    "<code>@NomeDoBot Nome do Filme</code>",
                    thread_id=getattr(call.message, 'message_thread_id', None),
                    parse_mode='HTML', reply_markup=kb_cancel)
                return

            # ── Baixar música ─────────────────────────────
            if sub == 'musica':
                bot.answer_callback_query(call.id)
                if not _cfg().get("musica_ativa"):
                    bot.answer_callback_query(call.id, "❌ Módulo de música desativado.", show_alert=True)
                    return
                if not is_auth_musica(uid):
                    bot.answer_callback_query(call.id, "🚫 Não autorizado.", show_alert=True)
                    return
                _pending[uid] = {
                    'action':    'search_musica',
                    'chat_id':   call.message.chat.id,
                    'thread_id': getattr(call.message, 'message_thread_id', None),
                }
                try: bot.delete_message(call.message.chat.id, call.message.message_id)
                except: pass
                kb_cancel = InlineKeyboardMarkup()
                kb_cancel.add(InlineKeyboardButton("❌ Cancelar", callback_data="usr|cancel"))
                qual = QUAL_LABEL.get(get_qual(uid), "?")
                send_msg(call.message.chat.id,
                    f"🎵 <b>Envie o link do Deezer ou Spotify</b>\n\n"
                    f"✅ <b>Aceitos:</b>\n"
                    f"  • <code>deezer.com/album/…</code>\n"
                    f"  • <code>deezer.com/track/…</code>\n"
                    f"  • <code>open.spotify.com/album/…</code>\n"
                    f"  • <code>open.spotify.com/track/…</code>\n\n"
                    f"🚫 <b>Não aceito:</b> links de playlist\n\n"
                    f"🎧 Sua qualidade: <b>{qual}</b>",
                    thread_id=getattr(call.message, 'message_thread_id', None),
                    parse_mode='HTML', reply_markup=kb_cancel)
                return

            # ── Download álbum via card (callback do botão no card) ──
            if sub == 'dl_alb':
                # Recupera dados armazenados em _pending pelo card
                bot.answer_callback_query(call.id)
                pend = _pending.pop(uid, {})
                dl_url  = pend.get('_dl_url') or (f"https://www.deezer.com/album/{parts[2]}" if len(parts) > 2 else None)
                dl_nome = pend.get('_dl_nome', 'Álbum')
                dl_tid  = pend.get('_dl_tid') or getattr(call.message, 'message_thread_id', None)
                dl_chat = pend.get('_dl_chat') or call.message.chat.id
                if not dl_url and len(parts) > 2:
                    dl_url = f"https://www.deezer.com/album/{parts[2]}"
                if not dl_url:
                    send_msg(dl_chat, "❌ URL perdida. Envie o link novamente.",
                             thread_id=dl_tid, parse_mode='HTML'); return
                if not is_auth_musica(uid) or not _cfg().get("musica_ativa"):
                    send_msg(dl_chat, "🚫 Sem permissão.", thread_id=dl_tid, parse_mode='HTML'); return
                try: bot.delete_message(call.message.chat.id, call.message.message_id)
                except: pass
                prog = send_msg(dl_chat, "⏳ Iniciando download do álbum…",
                                thread_id=dl_tid, parse_mode='HTML')
                threading.Thread(
                    target=_executar_download_e_enviar,
                    args=(dl_chat, dl_tid, uid, dl_url, True, prog.message_id, dl_nome),
                    daemon=True
                ).start()
                return

            # ── Download faixa via card ───────────────────
            if sub == 'dl_trk':
                bot.answer_callback_query(call.id)
                pend    = _pending.pop(uid, {})
                dl_url  = pend.get('_dl_url') or (f"https://www.deezer.com/track/{parts[2]}" if len(parts) > 2 else None)
                dl_nome = pend.get('_dl_nome', 'Faixa')
                dl_tid  = pend.get('_dl_tid') or getattr(call.message, 'message_thread_id', None)
                dl_chat = pend.get('_dl_chat') or call.message.chat.id
                if not dl_url and len(parts) > 2:
                    dl_url = f"https://www.deezer.com/track/{parts[2]}"
                if not dl_url:
                    send_msg(dl_chat, "❌ URL perdida. Envie o link novamente.",
                             thread_id=dl_tid, parse_mode='HTML'); return
                if not is_auth_musica(uid) or not _cfg().get("musica_ativa"):
                    send_msg(dl_chat, "🚫 Sem permissão.", thread_id=dl_tid, parse_mode='HTML'); return
                try: bot.delete_message(call.message.chat.id, call.message.message_id)
                except: pass
                prog = send_msg(dl_chat, "⏳ Iniciando download da faixa…",
                                thread_id=dl_tid, parse_mode='HTML')
                threading.Thread(
                    target=_executar_download_e_enviar,
                    args=(dl_chat, dl_tid, uid, dl_url, False, prog.message_id, dl_nome),
                    daemon=True
                ).start()
                return

            # ── Cancelar ─────────────────────────────────
            if sub == 'cancel':
                bot.answer_callback_query(call.id)
                _pending.pop(uid, None)
                try: bot.delete_message(call.message.chat.id, call.message.message_id)
                except: pass
                kb2, txt2 = kb_user_main(is_owner=(uid == OWNER_ID), uid=uid)
                send_msg(call.message.chat.id, txt2,
                         thread_id=getattr(call.message, 'message_thread_id', None),
                         parse_mode='HTML', reply_markup=kb2)
                return

        # ════════════════════════════════════════════════════
        # ADMIN — somente dono
        # ════════════════════════════════════════════════════
        if uid != OWNER_ID:
            bot.answer_callback_query(call.id, "🚫 Sem permissão."); return

        if action == 'adm':
            sub = parts[1]; bot.answer_callback_query(call.id)
            if   sub == 'main':       edit_or_send(call, *kb_admin_main())
            elif sub == 'urls':       edit_or_send(call, *kb_urls_menu())
            elif sub == 'grupos':     edit_or_send(call, *kb_grupos_menu())
            elif sub == 'musica':     edit_or_send(call, *kb_musica_menu())
            elif sub == 'stats':      edit_or_send(call, *kb_stats())
            elif sub == 'tog_musica':
                novo = not _cfg()["musica_ativa"]
                _cfg_set("musica_ativa", novo)
                lok(f"Módulo música: {'ATIVO' if novo else 'INATIVO'}")
                edit_or_send(call, *kb_admin_main())
            elif sub == 'close':
                try: bot.delete_message(call.message.chat.id, call.message.message_id)
                except: pass
            return

        # ── Música / autorizados ─────────────────────────────
        if action == 'mus':
            sub = parts[1]; bot.answer_callback_query(call.id)

            if sub == 'add':
                _pending[uid] = {'action': 'await_auth_uid'}
                send_msg(uid, "👤 <b>Envie o ID numérico do usuário a autorizar:</b>",
                         parse_mode='HTML'); return

            if sub == 'del' and len(parts) == 3:
                auth_remove(int(parts[2]))
                lok(f"Usuário {parts[2]} removido da música")
                edit_or_send(call, *kb_musica_menu()); return

            if sub == 'setq' and len(parts) == 3:
                target = parts[2]
                kb_q   = InlineKeyboardMarkup(row_width=3)
                kb_q.row(
                    InlineKeyboardButton("128kbps", callback_data=f"mus|qual|{target}|MP3_128"),
                    InlineKeyboardButton("320kbps", callback_data=f"mus|qual|{target}|MP3_320"),
                    InlineKeyboardButton("FLAC",    callback_data=f"mus|qual|{target}|FLAC"),
                )
                kb_q.add(InlineKeyboardButton("↩ Voltar", callback_data="adm|musica"))
                edit_or_send(call, kb_q, f"🎚 Qualidade para <code>{target}</code>:"); return

            if sub == 'qual' and len(parts) == 4:
                auth_set_qual(int(parts[2]), parts[3])
                lok(f"Qualidade {parts[2]} → {parts[3]}")
                edit_or_send(call, *kb_musica_menu()); return

            if sub == 'qual_pad' and len(parts) == 3:
                _cfg_set("qualidade_padrao", parts[2])
                lok(f"Qualidade padrão → {parts[2]}")
                edit_or_send(call, *kb_musica_menu()); return

            if sub == 'set_arl':
                _pending[uid] = {'action': 'await_arl'}
                send_msg(uid,
                    "🔑 <b>Configurar ARL do Deezer</b>\n\n"
                    "Envie a sua ARL (cookie de autenticação do Deezer).\n\n"
                    "📌 <b>Como obter:</b>\n"
                    "1. Acesse <a href='https://www.deezer.com'>deezer.com</a> e faça login\n"
                    "2. Abra as ferramentas do navegador (F12)\n"
                    "3. Vá em <b>Application → Cookies → deezer.com</b>\n"
                    "4. Copie o valor do cookie <code>arl</code>\n\n"
                    "⚠️ <b>Atenção:</b> a ARL é sensível — não compartilhe com ninguém!",
                    parse_mode='HTML'); return

        # ── URLs de streaming ─────────────────────────────────
        if action == 'url':
            sub = parts[1]
            if sub == 'add':
                bot.answer_callback_query(call.id)
                _pending[uid] = {'action': 'await_label',
                                 'menu_chat': call.message.chat.id,
                                 'menu_msg':  call.message.message_id}
                send_msg(uid, "📝 <b>Digite um nome para esta URL:</b>", parse_mode='HTML'); return
            if sub == 'use' and len(parts) == 3:
                ok, label = url_set_active(int(parts[2]))
                bot.answer_callback_query(call.id, f"✅ Usando: {label}" if ok else "Erro.")
                if ok: lok(f"URL ativa → {label}"); edit_or_send(call, *kb_urls_menu())
                return
            if sub == 'del' and len(parts) == 3:
                ok, label = url_remove(int(parts[2]))
                bot.answer_callback_query(call.id, f"🗑 Removida: {label}" if ok else "Erro.")
                if ok: lw(f"URL removida: {label}"); edit_or_send(call, *kb_urls_menu())
                return

        # ── Grupos ───────────────────────────────────────────
        if action == 'grp':
            sub = parts[1]
            if sub == 'add':
                bot.answer_callback_query(call.id)
                _pending[uid] = {'action': 'await_group_id',
                                 'menu_chat': call.message.chat.id,
                                 'menu_msg':  call.message.message_id}
                send_msg(uid,
                    "📌 <b>Adicionar Grupo</b>\n\n"
                    "Formato: <code>CHAT_ID THREAD_ID Nome</code>\n"
                    "Ex: <code>-1001234567890 5 Filmes HD</code>",
                    parse_mode='HTML'); return
            if sub == 'del' and len(parts) == 3:
                group_remove(int(parts[2]))
                bot.answer_callback_query(call.id, "✅ Grupo removido.")
                lw(f"Grupo removido: {parts[2]}")
                edit_or_send(call, *kb_grupos_menu()); return

        bot.answer_callback_query(call.id)

    except Exception as e:
        logging.error(f"h_callback: {e}"); le(f"Callback: {e}")
        try: bot.answer_callback_query(call.id, "❌ Erro interno.")
        except: pass

