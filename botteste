def api_get(creds, params, timeout=18):
    url = f"{creds['base']}/player_api.php"
    p   = {"username": creds["username"], "password": creds["password"]}
    p.update(params)
    r = requests.get(url, params=p, headers=HDR, timeout=timeout)
    r.raise_for_status(); return r.json()

