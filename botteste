# ── URLs de streaming / Credenciais ──────────────────────────────
def _urls():
    return _load(F_URLS, {"active": None, "list": []})

def extrair_creds(url):
    try:
        url = url.strip(); p = urlparse(url)
        host = p.hostname or ''; port = str(p.port) if p.port else '80'
        base = f"{p.scheme}://{host}:{port}"; qs = parse_qs(p.query)
        if 'username' in qs and 'password' in qs:
            return {"base": base, "host": host, "port": port,
                    "username": qs['username'][0], "password": qs['password'][0]}
        pts = [x for x in p.path.split('/') if x]
        if len(pts) >= 2 and not pts[0].endswith('.php'):
            return {"base": base, "host": host, "port": port,
                    "username": pts[0], "password": pts[1]}
    except Exception as e: logging.error(f"extrair_creds: {e}")
    return None

def url_add(url, label):
    creds = extrair_creds(url)
    if not creds:
        return False, ("❌ Não consegui extrair credenciais.\n\n"
                       "Formatos aceitos:\n"
                       "<code>http://host:80/get.php?username=U&password=P</code>\n"
                       "<code>http://host:80/player_api.php?username=U&password=P</code>\n"
                       "<code>http://host:80/U/P/arquivo</code>")
    data = _urls()
    for e in data["list"]:
        if e["creds"]["host"] == creds["host"] and e["creds"]["username"] == creds["username"]:
            return False, f"⚠️ URL já cadastrada como <b>{e['label']}</b>."
    data["list"].append({"label": label, "url": url, "creds": creds,
                         "added": datetime.now().isoformat()})
    if data["active"] is None: data["active"] = 0
    _save(F_URLS, data); return True, creds

def url_remove(idx):
    data = _urls(); lst = data["list"]
    if not (0 <= idx < len(lst)): return False, "Índice inválido."
    label = lst.pop(idx)["label"]
    if not lst: data["active"] = None
    elif data["active"] is not None:
        if data["active"] == idx: data["active"] = 0
        elif data["active"] > idx: data["active"] -= 1
    _save(F_URLS, data); return True, label

def url_set_active(idx):
    data = _urls()
    if not (0 <= idx < len(data["list"])): return False, ""
    data["active"] = idx; _save(F_URLS, data)
    return True, data["list"][idx]["label"]

def get_active_creds():
    data = _urls()
    if data["active"] is None or not data["list"]: return None
    idx = data["active"]
    return data["list"][idx]["creds"] if 0 <= idx < len(data["list"]) else None

