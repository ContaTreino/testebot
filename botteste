def loading_animation(chat_id, del_msg_id, thread_id=None):
    try:
        kw = {"message_thread_id": thread_id} if thread_id else {}
        lm = bot.send_message(chat_id, "🎬 Buscando... [░░░░░░░░░░] 0%", **kw)
        for i in range(1, 11):
            time.sleep(0.3)
            bar = "█" * i + "░" * (10 - i)
            bot.edit_message_text(f"🎬 Buscando... [{bar}] {i*10}%",
                                  chat_id=chat_id, message_id=lm.message_id)
        time.sleep(0.4)
        bot.delete_message(chat_id, lm.message_id)
        try: bot.delete_message(chat_id, del_msg_id)
        except: pass
    except Exception as e: logging.error(f"loading_animation: {e}")

